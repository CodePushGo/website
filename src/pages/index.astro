---
import Layout from '@/layouts/Layout.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = Astro.locals.locale
const config = Astro.locals.runtimeConfig

const homeUrl = getRelativeLocaleUrl(locale)
const docsUrl = getRelativeLocaleUrl(locale, 'docs/live-updates')
const pricingUrl = getRelativeLocaleUrl(locale, 'pricing')
const registerUrl = getRelativeLocaleUrl(locale, 'register')

const content = {
  title: 'CodePushGo - React Native Live Updates',
  description: 'Ship JavaScript bundle updates, hotfixes, staged rollouts, telemetry, and rollbacks for React Native apps without waiting on app store review.',
  image: `${config.public.baseUrl}/codepush_cover.webp`,
  keywords: 'React Native live updates, CodePush, OTA updates, JavaScript bundle updates, mobile release management, app rollback',
}

const proofLogos = [
  { name: 'Kick', src: '/kick_logo.webp' },
  { name: 'Pizza Hut', src: '/pizza_hut_logo.webp' },
  { name: 'RemNote', src: '/remnote_logo.svg' },
  { name: 'Revel', src: '/revel_logo.svg' },
  { name: 'XBE', src: '/xbe_logo.webp' },
  { name: 'IREC', src: '/irec_logo.webp' },
  { name: 'Suez', src: '/suez_logo.webp' },
  { name: 'Vella', src: '/vella_logo.svg' },
  { name: 'Ourliving', src: '/ourliving_logo.webp' },
]

const heroStats = [
  { value: 'Minutes', label: 'ship urgent JavaScript fixes' },
  { value: 'Channels', label: 'move updates through dev, beta, and production' },
  { value: 'Rollback', label: 'recover when a bundle behaves badly' },
  { value: 'Telemetry', label: 'see installs, failures, and active versions' },
]

const problemCards = [
  {
    title: 'Store review slows hotfixes',
    body: 'A small JavaScript bug can sit behind app review, phased release settings, and user update behavior.',
  },
  {
    title: 'Rollbacks are too heavy',
    body: 'Without a live update layer, a bad JavaScript release often means preparing another binary just to undo it.',
  },
  {
    title: 'Teams ship blind',
    body: 'Version drift, partial installs, and failed downloads need release telemetry instead of guesses from support tickets.',
  },
]

const featureHighlights = [
  {
    title: 'Live JavaScript bundles',
    description: 'Send JavaScript and asset updates to installed React Native apps after the binary is already in production.',
    icon: '<path d="M13 2L4 14h7l-1 8 10-13h-7V2z"></path>',
  },
  {
    title: 'Channel promotion',
    description: 'Move a bundle from development to beta to production without rebuilding the native app each time.',
    icon: '<path d="M4 6h16M4 12h10M4 18h7"></path><path d="M17 15l3 3-3 3"></path>',
  },
  {
    title: 'Staged rollout control',
    description: 'Start small, watch adoption, and expand the channel only when the update behaves correctly.',
    icon: '<path d="M4 18V6"></path><path d="M8 18V9"></path><path d="M12 18V4"></path><path d="M16 18v-6"></path><path d="M20 18v-3"></path>',
  },
  {
    title: 'Fast rollback path',
    description: 'Point a channel back to a known-good bundle when the newest release is not ready for all users.',
    icon: '<path d="M9 14l-4-4 4-4"></path><path d="M5 10h10a5 5 0 110 10h-2"></path>',
  },
  {
    title: 'Update telemetry',
    description: 'Track downloads, installs, failures, and active bundle versions while a release is rolling out.',
    icon: '<path d="M4 19V5"></path><path d="M4 19h16"></path><path d="M8 15l3-4 3 2 5-7"></path>',
  },
  {
    title: 'CLI-first workflow',
    description: 'Run the same upload command locally or from GitHub Actions, GitLab CI, Jenkins, or your own pipeline.',
    icon: '<path d="M4 7l6 5-6 5"></path><path d="M12 19h8"></path>',
  },
  {
    title: 'Version guardrails',
    description: 'Keep native app versions on their normal store path and target live updates only where they are compatible.',
    icon: '<path d="M12 3l8 4v6c0 4-3.4 7.7-8 8-4.6-.3-8-4-8-8V7l8-4z"></path><path d="M9 12l2 2 4-5"></path>',
  },
  {
    title: 'Open source core',
    description: 'Use a transparent update pipeline you can inspect, reason about, and connect to the rest of your release process.',
    icon: '<path d="M12 2a10 10 0 100 20 10 10 0 000-20z"></path><path d="M8 12h8"></path><path d="M12 8v8"></path>',
  },
]

const workflowSteps = [
  {
    step: '01',
    title: 'Connect the app',
    body: 'Install the React Native SDK once. The CLI creates config from the native bundle ID it detects in iOS or Android.',
    command: 'npx @codepushgo/cli@latest init',
  },
  {
    step: '02',
    title: 'Build the JavaScript bundle',
    body: 'Keep the existing React Native build process. The native binary still goes through the app stores when native code changes.',
    command: 'npm run build',
  },
  {
    step: '03',
    title: 'Upload to a channel',
    body: 'Publish a new JavaScript release to production, beta, or development from a laptop or CI pipeline.',
    command: 'npx @codepushgo/cli@latest release --platform ios --version 2.8.4 --channel production',
  },
  {
    step: '04',
    title: 'Watch adoption',
    body: 'Follow download and install state before expanding a rollout or promoting the bundle further.',
    command: 'npx @codepushgo/cli@latest bundle list',
  },
  {
    step: '05',
    title: 'Rollback if needed',
    body: 'Move the production channel back to a previous bundle from the console while the team investigates.',
    command: 'Console -> Channels -> Production -> select previous release',
  },
]

const monitoringStats = [
  { label: 'Downloaded', value: '86%', tone: 'bg-pumpkin-300' },
  { label: 'Ready after restart', value: '71%', tone: 'bg-vista-400' },
  { label: 'Failure rate', value: '0.4%', tone: 'bg-cornflower-300' },
]

const automationCards = [
  {
    title: 'Release from CI',
    body: 'Run the CLI after your JavaScript bundle build and keep signing, secrets, and app-store credentials outside the live update flow.',
  },
  {
    title: 'Promote, do not rebuild',
    body: 'Move a tested bundle between channels when it is ready instead of generating a new binary for every JavaScript change.',
  },
  {
    title: 'Separate native and JS paths',
    body: 'Native modules, permissions, and SDK upgrades keep their app-store release path. Live updates stay focused on bundle delivery.',
  },
]

const securityItems = [
  {
    title: 'End-to-end encrypted updates',
    body: 'Keep update delivery designed so only the intended app clients can decrypt the bundle payload.',
  },
  {
    title: 'Compatible-version targeting',
    body: 'Avoid sending a JavaScript bundle to native app versions that do not have the required binary capabilities.',
  },
  {
    title: 'Auditable release history',
    body: 'Keep a record of uploaded bundles, promoted channels, and rollback decisions for release review.',
  },
]

const boundaryColumns = [
  {
    title: 'Use live updates for',
    tone: 'border-vista-500/50 bg-white',
    marker: 'bg-vista-500',
    items: ['JavaScript bug fixes', 'Copy and UI changes shipped in JS', 'Bundled assets', 'Remote configuration handled by the app', 'Small rollout tests and recovery releases'],
  },
  {
    title: 'Use app-store releases for',
    tone: 'border-pumpkin-300/60 bg-white',
    marker: 'bg-pumpkin-400',
    items: ['Native modules', 'Permissions and entitlement changes', 'SDK upgrades', 'iOS or Android binary configuration', 'Anything requiring new native code'],
  },
]

const useCases = [
  'Fix a crash introduced by JavaScript logic',
  'Patch a checkout, login, or paywall screen',
  'Ship copy or visual changes tied to a campaign',
  'Stage a release to beta users before production',
  'Roll back a bad bundle while the team investigates',
  'Keep store releases for native changes only',
]

const faqItems = [
  {
    question: 'Does CodePushGo replace app store releases?',
    answer: 'No. It handles JavaScript bundle and asset updates. Native changes still go through the Apple App Store and Google Play release process.',
  },
  {
    question: 'Can I use it for React Native hotfixes?',
    answer: 'Yes. That is the core use case: publish a compatible JavaScript update to installed apps without waiting for a new binary review cycle.',
  },
  {
    question: 'How do teams keep releases controlled?',
    answer: 'Use channels, compatible-version targeting, telemetry, staged promotion, and rollback instead of sending every bundle straight to production.',
  },
  {
    question: 'Can it run from CI/CD?',
    answer: 'Yes. The CLI can run from GitHub Actions, GitLab CI, Jenkins, or any pipeline that builds the React Native JavaScript bundle.',
  },
]
---

<Layout content={content}>
  <main class="text-codepushgo-900 bg-white">
    <section class="bg-codepushgo-900 relative isolate overflow-hidden border-b border-white/15 text-white">
      <div
        class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(255,255,255,0.09)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.07)_1px,transparent_1px)] [background-size:76px_76px] opacity-35"
      >
      </div>
      <div class="from-codepushgo-800 absolute inset-x-0 bottom-0 -z-10 h-40 bg-linear-to-t to-transparent"></div>

      <div
        class="mx-auto grid max-w-7xl items-center gap-10 px-4 pt-12 pb-12 sm:px-6 sm:pt-16 lg:px-8 lg:pt-20 lg:pb-16 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] xl:gap-14"
      >
        <div class="max-w-2xl">
          <p class="border-pumpkin-200/40 bg-pumpkin-500/20 text-misty-300 inline-flex items-center rounded-lg border px-3 py-2 text-sm font-bold">
            Production recovery for React Native
          </p>
          <h1 class="mt-6 text-4xl leading-tight font-bold text-white sm:text-5xl lg:text-6xl">Ship React Native fixes without waiting for app review.</h1>
          <p class="text-misty-300 mt-6 text-lg leading-8">
            When a JavaScript bundle breaks production, CodePushGo gives your team a fast recovery path: publish a compatible update, watch adoption, and roll back before a bad
            release spreads.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href={registerUrl}
              class="text-codepushgo-900 hover:bg-misty-300 focus-visible:ring-offset-codepushgo-900 inline-flex min-h-12 items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-bold transition-colors focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:outline-none"
            >
              Start live updates
            </a>
            <a
              href={pricingUrl}
              class="bg-codepushgo-800 hover:bg-codepushgo-700 focus-visible:ring-misty-300 focus-visible:ring-offset-codepushgo-900 inline-flex min-h-12 items-center justify-center rounded-lg border border-white/20 px-6 py-3 text-base font-bold text-white transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
            >
              See pricing
            </a>
          </div>

          <dl class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-2">
            {
              heroStats.map((item) => (
                <div class="bg-codepushgo-800/80 shadow-codepushgo-900/30 rounded-lg border border-white/15 p-4 text-white shadow-lg">
                  <dt class="text-xl font-bold text-white">{item.value}</dt>
                  <dd class="text-misty-400 mt-1 text-sm leading-6">{item.label}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div class="min-w-0 xl:justify-self-end">
          <div class="text-codepushgo-900 w-full min-w-0 rounded-lg border border-white/20 bg-white shadow-2xl shadow-black/35 xl:max-w-[640px]">
            <div class="bg-dusk-900 flex items-center justify-between gap-4 rounded-t-lg border-b border-white/10 px-4 py-3 text-white">
              <div class="flex items-center gap-2" aria-hidden="true">
                <span class="bg-codepushgo-300 h-3 w-3 rounded-full"></span>
                <span class="bg-pumpkin-300 h-3 w-3 rounded-full"></span>
                <span class="bg-vista-400 h-3 w-3 rounded-full"></span>
              </div>
              <p class="text-misty-300 truncate font-mono text-xs font-bold">release/production</p>
            </div>

            <div class="grid gap-4 p-4 sm:p-6">
              <div class="border-codepushgo-900/15 bg-misty-300 rounded-lg border p-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-codepushgo-900 text-base font-bold">Bundle v2.8.4</p>
                    <p class="text-dusk-700 mt-1 text-sm leading-6">Payment fix promoted to Production</p>
                  </div>
                  <span class="bg-vista-500/25 text-dusk-900 rounded-md px-2 py-1 text-xs font-bold">Live</span>
                </div>
                <div class="mt-5 space-y-3">
                  {
                    monitoringStats.slice(0, 2).map((item) => (
                      <div>
                        <div class="text-dusk-700 mb-1 flex justify-between text-sm font-bold">
                          <span>{item.label}</span>
                          <span>{item.value}</span>
                        </div>
                        <div class="h-2 overflow-hidden rounded-full bg-white">
                          <div class={`h-full rounded-full ${item.tone}`} style={`width: ${item.value}`} />
                        </div>
                      </div>
                    ))
                  }
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="border-codepushgo-900/15 rounded-lg border bg-white p-4 shadow-sm">
                  <p class="text-codepushgo-900 text-base font-bold">Channels</p>
                  <div class="mt-4 space-y-3">
                    <div class="bg-misty-300 flex items-center justify-between gap-3 rounded-md px-3 py-2 text-sm font-bold">
                      <span>Production</span>
                      <span class="text-codepushgo-700">v2.8.4</span>
                    </div>
                    <div class="bg-misty-300 flex items-center justify-between gap-3 rounded-md px-3 py-2 text-sm font-bold">
                      <span>Beta</span>
                      <span class="text-codepushgo-900">v2.9.0</span>
                    </div>
                    <div class="bg-misty-300 flex items-center justify-between gap-3 rounded-md px-3 py-2 text-sm font-bold">
                      <span>Dev</span>
                      <span class="text-dusk-900">v3.0.0</span>
                    </div>
                  </div>
                </div>
                <div class="border-codepushgo-900/15 rounded-lg border bg-white p-4 shadow-sm">
                  <p class="text-codepushgo-900 text-base font-bold">Rollback guard</p>
                  <div class="border-vista-500/40 bg-vista-500/15 mt-4 rounded-md border p-3">
                    <p class="text-dusk-900 text-sm font-bold">Healthy rollout</p>
                    <p class="text-dusk-700 mt-2 text-sm leading-6">No failure spike detected. Keep monitoring before expanding the channel.</p>
                  </div>
                  <a
                    href={docsUrl}
                    class="text-codepushgo-700 hover:text-codepushgo-900 focus-visible:outline-pumpkin-200 mt-4 inline-flex min-h-11 items-center text-sm font-bold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
                  >
                  <a
                    href={docsUrl}
                    class="text-codepushgo-700 hover:text-codepushgo-900 focus-visible:outline-pumpkin-200 mt-4 inline-flex min-h-11 items-center text-sm font-bold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
                  >
                    Learn how rollback works
                  </a>
                </div>
              </div>

              <pre
                class="text-misty-100 bg-dusk-900 border-dusk-700 overflow-x-auto rounded-lg border p-4 text-xs leading-6 sm:text-sm"><code class="block whitespace-pre-wrap break-words">npm run build
npx @codepushgo/cli@latest release --platform ios --version 2.8.4 --channel production</code></pre>
    </section>

    <section class="border-codepushgo-900/10 text-codepushgo-900 bg-white py-12">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-center">
          <div>
            <p class="text-codepushgo-600 text-sm font-bold">Production proof</p>
            <h2 class="text-codepushgo-900 mt-2 text-2xl font-bold">Trusted by teams that need JavaScript recovery paths in production.</h2>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-3">
            {
              proofLogos.map((logo) => (
                <div class="border-codepushgo-900/15 bg-misty-50 shadow-codepushgo-900/10 flex min-h-20 items-center justify-center rounded-lg border p-4 shadow-sm">
                  <img loading="lazy" src={logo.src} alt={`${logo.name} logo`} width="160" height="80" class="max-h-10 w-auto object-contain" />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="bg-misty-300 text-codepushgo-900 py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div>
            <p class="text-codepushgo-700 text-sm font-bold">Release problem</p>
            <h2 class="mt-3 text-3xl leading-tight font-bold sm:text-4xl">A JavaScript bug should not turn into a multi-day app-store release.</h2>
            <p class="text-dusk-700 mt-5 text-lg leading-8">
              CodePushGo keeps the scope narrow and useful: ship compatible JavaScript changes to users, observe the rollout, and recover quickly when a bundle misbehaves.
            </p>
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            {
              problemCards.map((card) => (
                <article class="border-codepushgo-900/15 rounded-lg border bg-white p-6 shadow-sm">
                  <h3 class="text-codepushgo-900 text-xl font-bold">{card.title}</h3>
                  <p class="text-dusk-700 mt-3 text-base leading-7">{card.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="text-codepushgo-900 bg-white py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-codepushgo-600 text-sm font-bold">Live update platform</p>
          <h2 class="mt-3 text-3xl leading-tight font-bold sm:text-4xl">Everything points to one outcome: safer JavaScript releases.</h2>
          <p class="text-dusk-700 mt-4 text-lg leading-8">
            A focused release layer for bundle delivery, staged rollout, telemetry, rollback, and React Native operations without expanding into unrelated tooling.
          </p>
        </div>

        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            featureHighlights.map((feature) => (
              <article class="border-codepushgo-900/15 bg-misty-300 rounded-lg border p-6 shadow-sm">
                <div class="bg-codepushgo-900 flex h-11 w-11 items-center justify-center rounded-lg text-white">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
                    <g set:html={feature.icon} />
                  </svg>
                </div>
                <h3 class="text-codepushgo-900 mt-5 text-xl font-bold">{feature.title}</h3>
                <p class="text-dusk-700 mt-3 text-base leading-7">{feature.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="workflow" class="bg-misty-300 text-codepushgo-900 py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-codepushgo-600 text-sm font-bold">Workflow</p>
          <h2 class="mt-3 text-3xl leading-tight font-bold sm:text-4xl">A release path developers already understand.</h2>
          <p class="text-dusk-700 mt-4 text-lg leading-8">
            Keep your React Native build process. CodePushGo adds the upload, channel, telemetry, and rollback layer for JavaScript bundles.
          </p>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {
            workflowSteps.map((item) => (
              <article class="border-codepushgo-900/15 flex flex-col rounded-lg border bg-white p-5 shadow-sm">
                <span class="bg-codepushgo-900 inline-flex h-9 w-9 items-center justify-center rounded-lg text-sm font-bold text-white">{item.step}</span>
                <h3 class="text-codepushgo-900 mt-4 text-xl font-bold">{item.title}</h3>
                <p class="text-dusk-700 mt-3 text-base leading-7">{item.body}</p>
                <pre class="text-misty-100 bg-dusk-900 mt-6 min-h-24 overflow-x-auto rounded-lg p-4 text-xs leading-6 sm:text-sm">
                  <code class="block break-words whitespace-pre-wrap">{item.command}</code>
                </pre>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="monitoring" class="bg-misty-300 text-codepushgo-900 py-16 sm:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:px-8">
        <div>
          <p class="text-codepushgo-700 text-sm font-bold">Monitoring</p>
          <h2 class="mt-3 text-3xl leading-tight font-bold sm:text-4xl">Know whether the update actually reached users.</h2>
          <p class="text-dusk-700 mt-5 text-lg leading-8">
            A live update system needs more than an upload button. Teams need install state, failure signals, and enough version visibility to decide whether to expand, pause, or
            roll back.
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            {
              monitoringStats.map((item) => (
                <div class="border-codepushgo-900/15 rounded-lg border bg-white p-5">
                  <p class="text-dusk-700 text-sm font-bold">{item.label}</p>
                  <p class="text-codepushgo-900 mt-3 text-3xl font-bold">{item.value}</p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="border-codepushgo-900/15 shadow-codepushgo-900/10 rounded-lg border bg-white p-4 shadow-xl sm:p-6">
          <div class="border-codepushgo-900/15 bg-misty-300 text-codepushgo-900 rounded-lg border p-4">
            <div class="border-codepushgo-900/10 flex items-center justify-between border-b pb-4">
              <div>
                <p class="text-codepushgo-900 text-base font-bold">Production rollout</p>
                <p class="text-dusk-700 mt-1 text-sm leading-6">Bundle v2.8.4 across active app versions</p>
              </div>
              <span class="bg-vista-500/25 text-dusk-900 rounded-md px-3 py-1 text-sm font-bold">Stable</span>
            </div>
            <div class="mt-6 grid gap-4 sm:grid-cols-3">
              <div class="border-codepushgo-900/10 rounded-lg border bg-white p-4">
                <p class="text-dusk-700 text-sm font-bold">iOS active</p>
                <p class="text-codepushgo-900 mt-2 text-2xl font-bold">52%</p>
              </div>
              <div class="border-codepushgo-900/10 rounded-lg border bg-white p-4">
                <p class="text-dusk-700 text-sm font-bold">Android active</p>
                <p class="text-codepushgo-900 mt-2 text-2xl font-bold">48%</p>
              </div>
              <div class="border-codepushgo-900/10 rounded-lg border bg-white p-4">
                <p class="text-dusk-700 text-sm font-bold">Rollback target</p>
                <p class="text-codepushgo-900 mt-2 text-2xl font-bold">v2.8.3</p>
              </div>
            </div>
            <div class="mt-6 space-y-4">
              {
                monitoringStats.map((item) => (
                  <div>
                    <div class="text-dusk-700 mb-2 flex justify-between text-sm font-bold">
                      <span>{item.label}</span>
                      <span>{item.value}</span>
                    </div>
                    <div class="bg-codepushgo-900/10 h-3 overflow-hidden rounded-full">
                      <div class={`h-full rounded-full ${item.tone}`} style={`width: ${item.value}`} />
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

