---
import { getRelativeLocaleUrl } from 'astro:i18n'

const brand = Astro.locals.runtimeConfig.public.brand
const locale = Astro.locals.locale
const homeUrl = getRelativeLocaleUrl(locale)
const registerUrl = getRelativeLocaleUrl(locale, 'register')
const links = [
  { label: 'Live updates', href: `${homeUrl}#features` },
  { label: 'Workflow', href: `${homeUrl}#workflow` },
  { label: 'Monitoring', href: `${homeUrl}#monitoring` },
  { label: 'Security', href: `${homeUrl}#security` },
  { label: 'Pricing', href: getRelativeLocaleUrl(locale, 'pricing') },
  { label: 'FAQ', href: `${homeUrl}#faq` },
]
---

<header class="bg-codepushgo-900/95 relative z-50 border-b border-white/15 text-white backdrop-blur">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex min-h-16 items-center justify-between gap-4">
      <a
        href={homeUrl}
        aria-label={`${brand} home`}
        class="focus-visible:outline-pumpkin-200 flex min-h-12 items-center gap-3 rounded-lg pr-3 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
      >
        <img class="h-10 w-10 rounded-md object-contain" loading="eager" height="40" width="40" alt="" src="/logo.png" />
        <span class="text-lg font-bold tracking-normal text-white">{brand}</span>
      </a>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-misty-300 hover:bg-codepushgo-800 focus-visible:outline-pumpkin-200 inline-flex min-h-11 items-center rounded-lg px-3 text-sm font-bold transition-colors hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="https://github.com/CodePushGo/website"
          target="_blank"
          rel="noreferrer"
          class="text-misty-300 hover:bg-codepushgo-800 focus-visible:outline-pumpkin-200 inline-flex min-h-11 items-center rounded-lg px-3 text-sm font-bold transition-colors hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
          GitHub
        </a>
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <a
          href={registerUrl}
          class="text-codepushgo-900 hover:bg-misty-300 focus-visible:ring-offset-codepushgo-900 inline-flex min-h-11 items-center justify-center rounded-lg bg-white px-4 text-sm font-bold transition-colors focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          Start free
        </a>
      </div>

      <button
        type="button"
        class="bg-codepushgo-800 hover:bg-codepushgo-700 focus-visible:ring-pumpkin-100 focus-visible:ring-offset-codepushgo-900 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-white/20 text-white transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none lg:hidden"
        aria-label="Expand menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="menu-toggle"
      >
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="bg-codepushgo-900 hidden border-t border-white/15 lg:hidden">
    <nav class="mx-auto grid max-w-7xl gap-1 px-4 py-4 sm:px-6" aria-label="Mobile navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-misty-300 hover:bg-codepushgo-800 focus-visible:outline-pumpkin-200 flex min-h-11 items-center rounded-lg px-3 text-base font-bold hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com/CodePushGo/website"
        target="_blank"
        rel="noreferrer"
        class="text-misty-300 hover:bg-codepushgo-800 focus-visible:outline-pumpkin-200 flex min-h-11 items-center rounded-lg px-3 text-base font-bold hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
      >
        GitHub
      </a>
      <a
        href={registerUrl}
        class="text-codepushgo-900 hover:bg-misty-300 focus-visible:ring-offset-codepushgo-900 mt-2 flex min-h-12 items-center justify-center rounded-lg bg-white px-4 text-base font-bold focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:outline-none"
      >
        Start free
      </a>
    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle')
  const mobileMenu = document.getElementById('mobile-menu')

  menuToggle?.addEventListener('click', () => {
    const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true'
    menuToggle.setAttribute('aria-expanded', String(!isExpanded))
    mobileMenu?.classList.toggle('hidden')
  })
</script>
