---
import { getRelativeLocaleUrl } from 'astro:i18n'

const brand = Astro.locals.runtimeConfig.public.brand
const locale = Astro.locals.locale
const year = new Date().getFullYear()

interface NavigationItem {
  name: string
  href: string
  target?: string
  rel?: string
}

const navigation: Record<string, NavigationItem[]> = {
  product: [
    { name: 'Live updates', href: `${getRelativeLocaleUrl(locale)}#features` },
    { name: 'Workflow', href: `${getRelativeLocaleUrl(locale)}#workflow` },
    { name: 'Monitoring', href: `${getRelativeLocaleUrl(locale)}#monitoring` },
    { name: 'Security', href: `${getRelativeLocaleUrl(locale)}#security` },
    { name: 'Pricing', href: getRelativeLocaleUrl(locale, 'pricing') },
  ],
  learn: [
    { name: 'Setup guide', href: getRelativeLocaleUrl(locale, 'docs/getting-started/quickstart') },
    { name: 'FAQ', href: `${getRelativeLocaleUrl(locale)}#faq` },
    { name: 'Community', href: 'https://discord.com/invite/VnYRvBfgA6', target: '_blank', rel: 'noreferrer' },
    { name: 'GitHub', href: 'https://github.com/CodePushGo/website', target: '_blank', rel: 'noreferrer' },
  ],
  company: [
    { name: 'About', href: getRelativeLocaleUrl(locale, 'about') },
    { name: 'Trust', href: getRelativeLocaleUrl(locale, 'trust') },
    { name: 'Consulting', href: getRelativeLocaleUrl(locale, 'consulting') },
    { name: 'Contributing', href: getRelativeLocaleUrl(locale, 'contributing') },
  ],
  legal: [
    { name: 'Privacy', href: getRelativeLocaleUrl(locale, 'privacy'), rel: 'nofollow' },
    { name: 'Terms', href: getRelativeLocaleUrl(locale, 'tos'), rel: 'nofollow' },
    { name: 'Support policy', href: getRelativeLocaleUrl(locale, 'support-policy'), rel: 'nofollow' },
    { name: 'SLA', href: getRelativeLocaleUrl(locale, 'sla'), rel: 'nofollow' },
    { name: 'AUP', href: getRelativeLocaleUrl(locale, 'aup'), rel: 'nofollow' },
    { name: 'Security', href: getRelativeLocaleUrl(locale, 'security'), rel: 'nofollow' },
    { name: 'DPA', href: getRelativeLocaleUrl(locale, 'dpa'), rel: 'nofollow' },
  ],
}
---

<footer class="bg-codepushgo-900 border-t border-white/15 text-white" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_1.6fr]">
      <div>
        <a
          href={getRelativeLocaleUrl(locale)}
          aria-label={`${brand} home`}
          class="focus-visible:outline-pumpkin-200 inline-flex min-h-12 items-center gap-3 rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
        >
          <img src="/logo.png" width="40" height="40" alt="" loading="lazy" class="h-10 w-10 rounded-md object-contain" />
          <span class="text-lg font-bold text-white">{brand}</span>
        </a>
        <p class="text-misty-400 mt-5 max-w-md text-base leading-7">
          React Native live updates for JavaScript bundle and asset changes. Ship hotfixes, stage releases, and roll back without claiming native build or plugin features.
        </p>
        <div class="mt-6 flex gap-3">
          <a
            href="https://github.com/CodePushGo/website"
            target="_blank"
            rel="noreferrer"
            aria-label="CodePushGo on GitHub"
            class="bg-codepushgo-800 text-misty-300 hover:bg-codepushgo-700 focus-visible:outline-pumpkin-200 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-white/15 transition-colors hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
          >
            <svg viewBox="0 0 16 16" class="h-5 w-5" fill="currentColor" aria-hidden="true" focusable="false">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.65 7.65 0 018 3.36c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
          <a
            href="https://discord.com/invite/VnYRvBfgA6"
            target="_blank"
            rel="noreferrer"
            aria-label="CodePushGo community Discord"
            class="bg-codepushgo-800 text-misty-300 hover:bg-codepushgo-700 focus-visible:outline-pumpkin-200 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-white/15 transition-colors hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true" focusable="false">
              <path
                d="M20.32 4.37A19.8 19.8 0 0015.36 3c-.21.38-.46.9-.63 1.3a18.27 18.27 0 00-5.46 0A12.7 12.7 0 008.64 3c-1.73.3-3.4.76-4.96 1.37C.54 9.08-.31 13.67.1 18.2a19.9 19.9 0 006.08 3.07c.49-.66.92-1.36 1.3-2.1-.71-.27-1.4-.6-2.05-.98.17-.12.34-.25.5-.38a14.18 14.18 0 0012.14 0l.5.38c-.65.39-1.34.72-2.05.98.38.74.82 1.44 1.3 2.1a19.83 19.83 0 006.08-3.07c.5-5.25-.86-9.8-3.58-13.83zM8.02 15.42c-1.18 0-2.16-1.08-2.16-2.4 0-1.33.96-2.41 2.16-2.41 1.21 0 2.18 1.09 2.16 2.41 0 1.32-.95 2.4-2.16 2.4zm7.96 0c-1.18 0-2.16-1.08-2.16-2.4 0-1.33.95-2.41 2.16-2.41 1.21 0 2.18 1.09 2.16 2.41 0 1.32-.95 2.4-2.16 2.4z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {
          Object.entries(navigation).map(([section, links]) => (
            <div>
              <h3 class="text-sm font-bold text-white capitalize">{section}</h3>
              <ul role="list" class="mt-4 space-y-3">
                {links.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      target={item.target}
                      rel={item.rel}
                      class="text-misty-400 focus-visible:outline-pumpkin-200 inline-flex min-h-8 items-center text-sm leading-6 transition-colors hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4"
                    >
                      {item.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-10 border-t border-white/15 pt-8">
      <p class="text-misty-500 text-sm">&copy; {year} {brand}, Inc. All rights reserved.</p>
    </div>
  </div>
</footer>
